# ===========================================
# BUTTERFLY.GOV - Configuration Environment
# ===========================================
# Copiez ce fichier vers .env et remplissez vos clés
# L'app fonctionne en mode démo sans ces clés (sauf ANTHROPIC_API_KEY)

# ----- SUPABASE (BaaS) - OPTIONNEL -----
# Sans ces clés, l'app utilise un rate-limiting en mémoire
# Obtenez ces clés sur : https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----- ANTHROPIC (IA Claude) - REQUIS -----
# L'app ne fonctionne PAS sans cette clé !
# Obtenez votre clé sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ----- STRIPE (Paiements) - OPTIONNEL -----
# Pour activer l'abonnement Premium à 2,99€/mois
# Obtenez ces clés sur : https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ----- STRIPE PRODUCT -----
# 1. Créez un produit "Citoyen Premium" sur Stripe (Products > Add product)
# 2. Prix: 2,99€/mois récurrent
# 3. Copiez le Price ID (price_xxx) ici
STRIPE_PREMIUM_PRICE_ID=price_your-premium-price-id

# ----- APP CONFIG -----
NEXT_PUBLIC_BASE_URL=https://your-domain.com
